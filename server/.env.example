PORT=5000
NODE_ENV=development

# Frontend URL (comma separated for multiple origins)
CLIENT_URL=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key

# Firebase Service Account (Copy the content of your serviceAccountKey.json here as a single line string)
# Or leave empty if using serviceAccountKey.json file locally
FIREBASE_SERVICE_ACCOUNT=""
